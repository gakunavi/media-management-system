// ═══════════════════════════════════════════════════════════════════════════
//  MMS (メディア管理システム) — Prisma Schema
//  抽出元: docs/DESIGN.md「メディア管理システム（MMS）設計書 v5」全2,757行
//  対象:   PostgreSQL 16
//  生成:   P0-a（設計書全文からの実装仕様抽出）
//
//  ★このファイルがデータモデルの唯一の正（Single Source of Truth）。
//    設計書 §3 は「人が合意するための文書」であり、実装はこのファイルを読む。
//    設計書との対応: 各 model 直前に由来セクションを `/// §x.y` で明記。
//
//  ★model 総数 82（設計書の `^model ` 出現数と一致）
//    §3=49 / §3.6=8 / §3.7=4 / §3.8=7 / §3.9=4 / §3.10=3 / §11.4=1 / §16=6
//
//  ═══ 実装規約（設計書に記載が無いため P0-a で定めた。docs/PHASES.md §13 参照）═══
//   C-1: 主キーは全て `id String @id @default(cuid())`（設計書は `id` とだけ記載）
//   C-2: 外部キーは `<関連名>Id`。Prisma は双方向リレーション必須のため、
//        設計書に片側しか書かれていない関連にも逆側フィールドを追加している
//        （データ構造の追加ではなく Prisma 構文上の必須要件）
//   C-3: `...At` サフィックス = DateTime / `date` = DateTime @db.Date
//   C-4: 年月（month）は `String`（"YYYY-MM"）。ただし §3.8.1 SeasonalityIndex は
//        設計書に `// 1-12` と明記されているため Int
//   C-5: 金額は Decimal @db.Decimal(14, 2)（§16.6-7 により全て税抜で保持）
//   C-6: enum 化するのは設計書に `// a | b | c` と値が列挙されているものだけ。
//        列挙が無い／`…` で打ち切られている項目は String のまま（推測で補わない）
//   C-7: 設計書に `?` が無くても、行の作成時点で論理的に未確定な項目は Nullable に
//        している。該当項目は全て docs/PHASES.md §8 に列挙した
//   C-8: 全82モデルに `createdAt DateTime @default(now())` / `updatedAt DateTime @updatedAt`
//        を一律付与している（docs/PHASES.md §9-D11 の決定）。新規モデルにも必ず付ける
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("MMS_DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
//  ENUM 定義
//  設計書に `// a | b | c` 形式で値が明示されているものだけを enum 化している。
//  値が列挙されていない項目（Business.status / Keyword.intent / Idea.state 等）は
//  String のままとし、docs/PHASES.md §13 未解決リストに記録した。
// ═══════════════════════════════════════════════════════════════════════════

/// §3 Target.tier — KPIツリーの階層
enum TargetTier {
  north_star
  leading
  guardrail
}

/// 記事の読者（2026-07-23 石井さん）。
///
/// ★`budgetTier` を記事に流用したのは誤りだった。あれは商談相手の予算を表す区分で、
///   記事から読者の予算規模は決まらない（同じ両替機の記事を1台350万で買う人と
///   数千万分買う人が読む）。記事について確実に言えるのは「誰に向けて書いたか」だけ。
///
/// ★これで「法人向け記事のPVは伸びているか」「個人事業主向けからの送客は多いか」を
///   分けて見られる。主力商材（ML 240万・両替機 350万）の買い手は法人なので、
///   corporate と both が買い手に繋がる読者。
enum ContentAudience {
  /// 法人・経営者向け（設備投資・制度活用）
  corporate
  /// 個人事業主・フリーランス向け
  sole_proprietor
  /// 両方が読む（税制改正・法改正など読者を選ばないもの）
  both
  /// 税理士・代理店向け。★商材の買い手ではない（買い手の分母から外す）
  partner
}

/// 記事の型（2026-07-23 石井さん）。★既存 ArticleType（pillar/cluster/news…）は
/// サイト構造上の役割で、こちらは**内容の型**。どちらも要るので別軸で持つ。
///
/// ★これで「どの型がPVを稼ぐか」「どの型が送客に効くか」を分けて見られる。
/// 実測（2026-07-23）では唯一の成約が comparison（主力5商材の比較）から出ている。
enum ContentFormat {
  /// 特定商材の解説（GPU・外貨両替機・航空機リース…）
  product
  /// 複数の選択肢を比べる。★買う直前の読者が来る
  comparison
  /// 税制・制度の解説（経営強化税制・少額減価償却…）
  system
  /// 時事・法改正・速報
  news
  /// 実務手順（申請フロー・書き方・チェックリスト）
  howto
  /// リスク・否認・失敗・倒産事例。★買う前の不安を潰す
  risk
  /// 導入事例・インタビュー
  case_study
}

