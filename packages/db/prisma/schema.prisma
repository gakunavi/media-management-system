// ═══════════════════════════════════════════════════════════════════════════
//  ══ 1. 事業・チャネル・目標 ══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══1. 事業（節税商材代理店 / 将来: コンテンツ販売 …）
/// §10: 新規事業の追加は「Business を1行INSERT」で済む（スキーマ変更なし）
model Business {
  id     String @id @default(cuid())
  slug   String @unique
  name   String
  /// 値の列挙が設計書に無いため String（§13 記録済）
  status String

  channels        Channel[]
  targets         Target[]
  experiments     Experiment[]
  metricSnapshots MetricSnapshot[]
  leads           Lead[]
  keywords        Keyword[]
  ideas           Idea[]
  actions         Action[]
  learnings       Learning[]
  topicClusters   TopicCluster[]
  keywordClusters KeywordCluster[]
  adAccounts      AdAccount[]
  unitEconomics   UnitEconomics[]
  adSimulations   AdSimulation[]
  landingPages    LandingPage[]
  toolSubscriptions ToolSubscription[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// §3 ══1. チャネル（media / threads / instagram / line / agency_lp / note …）
/// ★accountRef により「プラットフォーム × アカウント単位」で分離（§11.1 でこの設計が効く）
model Channel {
  id         String @id @default(cuid())
  businessId String
  /// 設計書の列挙が `…` で打ち切られているため String（§13 記録済）
  type       String
  /// アカウント単位の識別子。§11.3 の投稿誤爆防止ガードの起点
  accountRef String
  name       String
  /// アカウント資格情報を含む。worker は channelId 経由でしかトークンを引けない（§11.3）
  config     Json

  business             Business              @relation(fields: [businessId], references: [id])
  contentItems         ContentItem[]
  metricSnapshots      MetricSnapshot[]
  measurementCoverages MeasurementCoverage[]
  leads                Lead[]
  snsAccountHealth     SnsAccountHealth[]
  postSchedules        PostSchedule[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, type, accountRef])
  @@index([businessId])
  @@index([type])
}

/// §3 ══1. 目標（KPIツリーの階層を持つ）
/// parentMetric で inquiries ← lp_view ← cta_click ← clicks ← impressions を繋ぐ
model Target {
  id           String     @id @default(cuid())
  businessId   String
  /// 対象期間（例: "2026-07"）。C-4
  period       String
  metric       String
  targetValue  Float
  tier         TargetTier
  /// KPIツリーの親メトリクス名
  parentMetric String?

  business Business @relation(fields: [businessId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, period, metric])
  @@index([businessId, period])
  @@index([tier])
}

// ═══════════════════════════════════════════════════════════════════════════
//  ══ 2. 計測（欠測とゼロを厳密に区別）══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══2. 汎用メトリクス
/// §10: 新指標の追加は metric に値が増えるだけ（マイグレーション不要）
model MetricSnapshot {
  id          String   @id @default(cuid())
  businessId  String
  channelId   String?
  metric      String
  value       Float
  date        DateTime @db.Date
  /// 値の列挙が設計書に無いため String（日次/週次/月次を想定・§13 記録済）
  granularity String

  business Business @relation(fields: [businessId], references: [id])
  channel  Channel? @relation(fields: [channelId], references: [id])

  /// ★設計書に明記。ただし channelId が NULL の行は Postgres の NULL 非同値により
  ///   一意制約が効かない（§13 記録済）

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, channelId, metric, date, granularity])
  @@index([businessId, metric, date])
  @@index([date])
}

/// §3 ══2. ★★ 計測期間の記録 — 直客2件の見逃し事故の再発防止装置
///
/// ★★★ 規約（絶対・docs/RULES.md にも記載）★★★
///   行が存在しない = 「未計測」。UI/APIは "—(未計測)" と表示し、決してゼロと書かない
///   value = 0      = 「実測ゼロ」
///   MeasurementCoverage に期間が無い指標は、集計・グラフ・brief から physically 除外する
///   → 「問い合わせ 0」と「問い合わせ 未計測」を二度と混同しない
model MeasurementCoverage {
  id        String    @id @default(cuid())
  metric    String
  channelId String?
  startedAt DateTime
  /// 計測継続中は NULL
  endedAt   DateTime?
  /// 計測手段。値の列挙が設計書に無いため String（§13 記録済）
  method    String
  note      String?

  channel Channel? @relation(fields: [channelId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([metric, startedAt])
  @@index([channelId])
}

// ═══════════════════════════════════════════════════════════════════════════
//  ══ 3. コンテンツ（記事・投稿・リール・LP を統一）══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══3. コンテンツ統一モデル（ART-088 / THR-076 / LP-001 …）
/// 記事本文の正は WordPress。本モデルはメタ・計測・バージョンを持つ（§16.6-8）
model ContentItem {
  id         String  @id @default(cuid())
  channelId  String
  /// ART-088 / THR-076 / LP-001
  externalId String
  /// 値の列挙が §3 に無いため String（articleType とは別軸・§13 記録済）
  type       String
  title      String
  /// 公開前は未確定のため Nullable（C-7）
  url        String?
  /// 値の列挙が設計書に無いため String（旧Notion「制作ステータス」・§13 記録済）
  status     String

  // ── 分類（旧Notion 記事パフォーマンス管理DB から移行・§7.1）──
  articleType   ArticleType? /// ★P1 移行時点では未確定のため Nullable（C-7）。P3.5/P4.9 で確定させる
  /// 内容の型（商材 / 比較 / 制度 / 時事 / 実務 / リスク / 事例）。2026-07-23 追加
  contentFormat ContentFormat?
  isPillar      Boolean      @default(false)
  category      String?
  /// ★KeywordAssignment(role=main) と二重の正になりうる（§13 記録済）
  mainKeywordId String?
  charCount     Int?
  eyecatchType  String?
  eyecatchColor String?
  targetLabel   String?
  wpPostId      Int?
  wpCategoryId  Int?
  tagIds        Int[]

  // ── ★鮮度管理（3階層ケイデンス・content-standards.md 準拠・§7.5）──
  /// 公開日（未公開は NULL・C-7）
  publishedAt    DateTime?
  /// 情報基準日（YMYL必須・記事内に表示）
  infoBaseDate   DateTime?
  /// dateModified。★実質追記時のみ更新。cosmetic では触らない（§7.5.1）
  dataUpdatedAt  DateTime?
  /// 最終チェック日（記事に "last reviewed: YYYY-MM" として表示）
  lastReviewedAt DateTime?
  freshnessTier  FreshnessTier? /// ★P1 移行時点では未確定のため Nullable（C-7）。P3.5/P4.9 で確定させる
  /// ★lastReviewedAt + FreshnessRule.intervalDays（自動算出）
  nextReviewDue  DateTime?
  reviewState    ReviewState    @default(fresh)

  // ── 品質ゲートの判定結果（旧Notion）──
  seoCheckPassed    Boolean @default(false)
  /// 値の列挙が設計書に無いため String（§13 記録済）
  complianceVerdict String?
  /// 値の列挙が設計書に無いため String（§13 記録済）
  factCheckVerdict  String?
  /// validate-article / seo-lint / ai-tone / geo-checks の結果
  validatorRun      Json?

  // ── AIO（旧Notion AIO計測DB・§7.2）──
  aioTier          AioTier   @default(none)
  aioTracked       Boolean   @default(false)
  aioTierUpdatedAt DateTime?
  aioNote          String?

  // ── 買い手軸（2026-07-20 実データで訂正済み・§14.1）──
  budgetTier    BudgetTier   @default(unknown)
  funnelStage   FunnelStage? /// ★P1 移行時点では未確定のため Nullable（C-7）。P3.5/P4.9 で確定させる
  /// ML | IoTビーコン | 外貨両替機 | EV充電 | GPU …
  productFit    String[]
  /// 読者（2026-07-23 石井さんと確定して enum 化）。
  /// ★String[] のままだと表記ゆれが入り、集計が割れる（実際 0件のまま使われていなかった）。
  ///   複数指定できる形は残す（「法人にも個人事業主にも効く記事」が実在する）
  audience      ContentAudience[]
  buyerFitScore Int?
  /// ★効く結果指標（必須・APIで弾く。§5.5 結果フォーカスの構造的強制）
  impacts       String[]
  note          String?

  channel Channel @relation(fields: [channelId], references: [id])

  metrics             ContentMetric[]
  aioCitations        AioCitation[]
  ctas                Cta[]
  reviews             ArticleReview[]
  keywordAssignments  KeywordAssignment[]
  clusters            ContentCluster[]
  pillarOfClusters    TopicCluster[]         @relation("ClusterPillar")
  outgoingLinks       InternalLink[]         @relation("LinkSource")
  incomingLinks       InternalLink[]         @relation("LinkTarget")
  landingSessions     VisitorSession[]       @relation("SessionLanding")
  funnelEvents        FunnelEvent[]
  firstTouchLeads     Lead[]                 @relation("LeadFirstTouch")
  lastTouchLeads      Lead[]                 @relation("LeadLastTouch")
  lineFriends         LineFriend[]
  ideas               Idea[]
  interventions       Intervention[]
  indexStatuses       IndexStatus[]
  leadTouchpoints     LeadTouchpoint[]
  backlinks           Backlink[]
  pageExperiences     PageExperience[]
  productionCosts     ProductionCost[]
  lifecycles          ContentLifecycle[]     @relation("LifecycleSubject")
  mergeTargetOf       ContentLifecycle[]     @relation("LifecycleMergeTarget")
  splitAssignments    SplitAssignment[]
  crossPromotionsFrom CrossPromotion[]       @relation("PromotionArticle")
  crossPromotionsTo   CrossPromotion[]       @relation("PromotionPost")
  linkChecks          LinkCheck[]
  provenances         GenerationProvenance[]
  versions            ContentVersion[]
  queries             ContentQuery[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, externalId])
  @@index([channelId])
  @@index([articleType])
  @@index([status])
  @@index([budgetTier, funnelStage])
  @@index([reviewState, nextReviewDue])
  @@index([publishedAt])
  @@index([mainKeywordId])
}

/// §3 ══3. ★リライト/レビューの履歴（いつ何を見て何をしたか）
model ArticleReview {
  id                   String               @id @default(cuid())
  contentItemId        String
  reviewedAt           DateTime
  reviewer             ReviewerType
  kind                 ArticleReviewKind
  /// 古くなった数値・失効した制度・順位低下
  findings             Json?
  outcome              ArticleReviewOutcome
  /// 実質追記だったか（cosmetic なら false → dataUpdatedAt を更新しない）
  updatedDataUpdatedAt Boolean              @default(false)
  /// 効果測定に接続
  interventionId       String?

  contentItem  ContentItem   @relation(fields: [contentItemId], references: [id])
  intervention Intervention? @relation(fields: [interventionId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contentItemId, reviewedAt])
  @@index([kind])
  @@index([outcome])
}

/// §3 ══3. 鮮度ケイデンスの定義（変更可能にする）
/// 既定値: breaking=0(随時) / commercial=75 / evergreen=180 / reference=365（§7.5.1）
model FreshnessRule {
  id            String        @id @default(cuid())
  freshnessTier FreshnessTier @unique
  intervalDays  Int
  description   String?

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// §3 ══3. コンテンツ別の日次メトリクス
/// clicks / impressions / position / views / aio_hit / reel_views / note_views …
/// §3.9.6: リール指標は metric 名を増やすだけで対応できる（スキーマ変更なし）
/// §3.2.2: ★日次を永久保持。GSC APIは16ヶ月しか遡れないため自前DBが唯一の長期履歴
model ContentMetric {
  id            String   @id @default(cuid())
  contentItemId String
  metric        String
  value         Float
  date          DateTime @db.Date

  contentItem ContentItem @relation(fields: [contentItemId], references: [id])

  /// ★設計書に明記なし。日次 backfill の冪等性を担保するため追加（§13 記録済）

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentItemId, metric, date])
  @@index([contentItemId, metric, date])
  @@index([date])
  @@index([metric, date])
}

/// 記事が**実際に何で検索されて表示されたか**（GSC page×query・2026-07-23 追加）
///
/// ★なぜ要るか
///   これが無いと「記事のメインKW」を実測から決められない。179記事すべてで
///   mainKeyword が空だったのは、埋める材料がどこにも無かったからである。
///   既存の Keyword(420件) はラッコの調査KWで「狙っているKW」、
///   こちらは「実際に来ているKW」。**両者は一致しない**（そのズレ自体が打ち手になる）。
///
/// ★なぜ日次にしないか
///   page×query の日次は行数が跳ね、しかも大半は0〜1表示のノイズになる。
///   GSC 側も日次×query では閾値で行が落ちる。
///   **期間の集計スナップショット**として持ち、週次で更新する。
///   期間を列に持つので「いつの28日間か」が必ず分かる（§3 未計測との区別）。
///
/// ★position は期間内の平均（GSCの定義）。加重平均ではないので合算してはいけない。
model ContentQuery {
  id            String   @id @default(cuid())
  contentItemId String
  /// 検索語そのもの。Keyword テーブルとは紐づけない（調査KWと実測KWは別物）
  query         String
  clicks        Int      @default(0)
  impressions   Int      @default(0)
  ctr           Float?
  position      Float?
  /// 集計期間（含む）
  periodStart   DateTime @db.Date
  /// 集計期間（**含む**。GSC の end_date と同じ）
  periodEnd     DateTime @db.Date

  contentItem ContentItem @relation(fields: [contentItemId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentItemId, query, periodStart, periodEnd])
  @@index([contentItemId, clicks])
  @@index([periodEnd, position])
  @@index([query])
}

/// AIO計測で「誰が引用されたか」を残す（2026-07-23 追加・低優先の生データ保存）
///
/// ★なぜ ContentMetric に入れないか
///   ContentMetric は (contentItemId, metric, date) → Float の器で、
///   ドメイン名を metric 文字列に埋めると名前空間が無制限に肥大する
///   （aio_competitor_moneyforward … のように増え続ける）。
///
/// ★なぜ ChatGPT だけか
///   実測（2026-05〜06 の3353試行）で Gemini は自社0% / 競合0.2% と、
///   そもそも特定サイトを引用する挙動をほぼ持たない。保存しても読む価値がない。
///     chatgpt 1971試行 自社74(3.8%) 競合90(4.6%)
///     gemini  1382試行 自社 0(0.0%) 競合 3(0.2%)
///
/// ★何に使うか（今は保存だけ。画面もアラートも作らない）
///   現状 ChatGPT の被引用は中小企業庁など公的機関が中心で、
///   民間競合には負けていない。**民間競合が現れた時点**が打ち手の分岐なので、
///   その瞬間を後から辿れるように生データだけ残す。
model AioCitation {
  id            String   @id @default(cuid())
  contentItemId String
  /// 現状 "chatgpt" のみ（上記の理由で gemini は保存しない）
  engine        String
  date          DateTime @db.Date

  /// 実際に引用されたURLのホスト。既知リストに無い競合もここで見つかる
  citedDomains     String[]
  /// COMPETITOR_PATTERNS で検出した既知キー（moneyforward / chusho_gov 等）
  citedCompetitors String[]
  /// ★民間競合が1つでも出たか。公的機関(.go.jp)だけなら false。
  ///   「民間競合が現れた」検知をこの1列で済ませるために持つ
  hasPrivateCompetitor Boolean @default(false)

  contentItem ContentItem @relation(fields: [contentItemId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentItemId, engine, date])
  @@index([date])
  @@index([hasPrivateCompetitor])
}

/// §3 ══3. 記事内CTA（位置別に効果を測る）
model Cta {
  id            String      @id @default(cuid())
  contentItemId String
  position      CtaPosition
  variant       String?
  targetUrl     String
  active        Boolean     @default(true)

  contentItem  ContentItem   @relation(fields: [contentItemId], references: [id])
  funnelEvents FunnelEvent[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contentItemId, position])
  @@index([active])
}

// ═══════════════════════════════════════════════════════════════════════════
//  ══ 4. ファネル7段（記事→問い合わせの間を全部計測する）══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══4. 訪問セッション（1st-party Cookie・GA4に頼らず自前で持つ・§14.2）
/// 保存期間 13ヶ月（§16.2）。DataRetentionPolicy により自動削除
model VisitorSession {
  id               String   @id @default(cuid())
  visitorId        String
  firstSeenAt      DateTime
  landingContentId String?
  referrer         String?
  utm              Json?
  /// ?from=media&article=ART-XXX
  fromParam        String?
  pageviews        Int      @default(0)
  converted        Boolean  @default(false)

  // ── §3.6.6 AI検索からの流入（referrer を正規化して判別）──
  trafficSource TrafficSource?
  aiEngine      AiEngine?

  // ── §3.7.2 A/B の群割当（Cookieで固定・再訪時に同じ群）──
  /// ★モデルと計測は P2.5 で先に作る（後入れ不可）。実装は P7.7
  variantAssignments Json?

  landingContent ContentItem? @relation("SessionLanding", fields: [landingContentId], references: [id])

  funnelEvents FunnelEvent[]
  leads        Lead[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitorId])
  @@index([firstSeenAt])
  @@index([landingContentId])
  @@index([trafficSource])
  @@index([converted])
}

/// §3 ══4. ファネルイベント（7段・§14.2）
/// §16.1-④ 冪等キーで重複排除（二重計測を物理的に防ぐ）
/// §3.10.3 計測タグ設計原則の適用対象。1ページ1回送信・sendBeacon・throttle 250ms
model FunnelEvent {
  id            String     @id @default(cuid())
  sessionId     String
  occurredAt    DateTime
  step          FunnelStep
  contentItemId String?
  ctaId         String?
  lpId          String?
  meta          Json?

  session     VisitorSession @relation(fields: [sessionId], references: [id])
  contentItem ContentItem?   @relation(fields: [contentItemId], references: [id])
  cta         Cta?           @relation(fields: [ctaId], references: [id])
  landingPage LandingPage?   @relation(fields: [lpId], references: [id])

  /// §16.1-④ 冪等キー: (sessionId, step, contentItemId, occurredAt秒)
  /// ★contentItemId が NULL の行では Postgres の NULL 非同値により効かない（§13 記録済）

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, step, contentItemId, occurredAt])
  @@index([sessionId, occurredAt])
  @@index([step, occurredAt])
  @@index([contentItemId, step])
  @@index([lpId, step])
}

// ═══════════════════════════════════════════════════════════════════════════
//  ══ 5. リード・成約（獲得3ゴールを型で分ける）══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══5. リード（§14.3）
/// ★MMS はリードまで。商談以降は m2（ML営業管理システム）が正（§3.8.4）
/// §16.2: 個人情報カラムは列単位で暗号化。アクセスは AuditLog に記録
/// §16.2: AIへの受け渡しでは氏名・連絡先をマスキングする（興味商材と閲覧履歴のみ渡す）
model Lead {
  id              String    @id @default(cuid())
  businessId      String
  type            LeadType
  occurredAt      DateTime
  /// ★初動速度。SLA 1時間を段1で監視（§5.4）
  firstResponseAt DateTime?

  // ── 誰か ──
  /// ── 個人情報（★§16.2「Lead の個人情報カラムは列単位で暗号化」）──
  /// ★設計書 §3 の Lead 定義にはこの4列が無いが、§16.2 が暗号化対象として
  ///   「Lead の個人情報カラム」を明示し、§5.4 が自動返信メールを要求している。
  ///   列が無いと P2（フォーム → Lead）が成立しないため P2 で補った。→ §9-D18 / §8 U41
  /// ★保存形式は AES-256-GCM の封筒（`v1:iv:tag:ct`）。**平文では絶対に保存しない**。
  ///   復号は apps/web/lib/crypto.ts の decryptPii() のみ。
  ///   AI に渡すときは必ずマスキングする（§16.2 / docs/RULES.md §11-1）
  contactName  String?
  contactEmail String?
  contactPhone String?
  companyName  String?

  /// 値の列挙が設計書に無いため String（§13 記録済）
  companyType     String?
  budgetTier      BudgetTier @default(unknown)
  interestProduct String[]
  /// 値の列挙が設計書に無いため String（§13 記録済）
  urgency         String?

  // ── どこから（first / last touch 両方を保持。主指標は last touch・§16.6-2）──
  firstTouchContentId   String?
  lastTouchContentId    String?
  sourceKeywordId       String?
  sourceChannelId       String?
  sessionId             String?
  /// ★「ビーコン/外貨両替機」のような比較対象 = 金脈KWの源泉（§3.1）
  competitorsConsidered String[]

  // ── その後 ──
  status       LeadStatus     @default(new)
  closedAmount Decimal?       @db.Decimal(14, 2)
  closedAt     DateTime?
  sourceType   LeadSourceType
  /// 送客元（きっかけ）。★受け皿と直交する軸。電話・メールでも聞けば埋まる
  origin       LeadOrigin     @default(unknown)

  // ── §3.8.4 m2 連携（★商談以降は m2 が正）──
  m2DealId       String?
  m2SyncedAt     DateTime?
  m2Stage        String?
  m2ClosedAmount Decimal?  @db.Decimal(14, 2)
  m2ClosedAt     DateTime?

  note String?

  business          Business        @relation(fields: [businessId], references: [id])
  firstTouchContent ContentItem?    @relation("LeadFirstTouch", fields: [firstTouchContentId], references: [id])
  lastTouchContent  ContentItem?    @relation("LeadLastTouch", fields: [lastTouchContentId], references: [id])
  sourceKeyword     Keyword?        @relation(fields: [sourceKeywordId], references: [id])
  sourceChannel     Channel?        @relation(fields: [sourceChannelId], references: [id])
  session           VisitorSession? @relation(fields: [sessionId], references: [id])

  touchpoints    LeadTouchpoint[]
  convertedFrom  LineFriend[]
  consentRecords ConsentRecord[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, type, occurredAt])
  @@index([status])
  @@index([sourceType])
  @@index([firstTouchContentId])
  @@index([lastTouchContentId])
  @@index([m2DealId])
}

// ═══════════════════════════════════════════════════════════════════════════
//  ══ 6. 代理店 ══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══6. 代理店リード（Threads代理店募集トラック → DM → 自己選別・§14.4）
model AgencyLead {
  id               String          @id @default(cuid())
  threadsUserId    String
  receivedAt       DateTime
  /// どの投稿からのDMか
  sourcePostId     String?
  stage            AgencyLeadStage
  screeningAnswers Json?
  forwardedAt      DateTime?
  partnerId        String?

  partner Partner? @relation(fields: [partnerId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([receivedAt])
  @@index([sourcePostId])
}

/// 代理店LP（外部ドメイン）の日次流入。配布URL `?ag=AG-XXXX` 単位。
///
/// ★なぜ MMS が持つのか
///   代理店募集は Threads の4目的の1つだが、MMS が持っていたのは DM だけで、
///   「配布した代理店コードから実際に何人来て何件問い合わせたか」が無かった。
///   どの代理店が動いているかは、この数字でしか分からない。
///
/// ★PII は持ち込まない。取得元CSVには氏名・メールアドレスが含まれるが、
///   MMS が必要なのは件数だけ。持たなければ守る必要も無い（§16.2）。
model AgencyLpDaily {
  id   String   @id @default(cuid())
  /// LP識別子（例: bousai-bouhan-light）
  lp   String
  date DateTime @db.Date
  /// AG-0096 など。コード無しの流入は "direct"
  agencyCode String
  visits     Int @default(0)
  inquiries  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lp, date, agencyCode])
  @@index([date])
  @@index([agencyCode])
}

/// §3 ══6. 代理店（稼働しているかを追う）
model Partner {
  id              String    @id @default(cuid())
  name            String
  parentPartnerId String?
  commissionRate  Float
  /// 値の列挙が設計書に無いため String（§13 記録済）
  status          String
  /// 稼働しているか（§14.4 稼働代理店のプロファイル逆算に使う）
  lastDealAt      DateTime?
  dealCount       Int       @default(0)
  totalAmount     Decimal   @default(0) @db.Decimal(14, 2)

  parentPartner Partner?     @relation("PartnerHierarchy", fields: [parentPartnerId], references: [id])
  childPartners Partner[]    @relation("PartnerHierarchy")
  agencyLeads   AgencyLead[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([parentPartnerId])
  @@index([lastDealAt])
}

// ═══════════════════════════════════════════════════════════════════════════
//  ══ 7. LINE ══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══7. LINE友だち（§14.5・現状0人。登録経路はURLパラメータで記事別に分離）
model LineFriend {
  id              String   @id @default(cuid())
  lineUserId      String   @unique
  addedAt         DateTime
  sourceContentId String?
  sourceParam     String?
  tags            String[]
  /// 値の列挙が設計書に無いため String（§13 記録済）
  status          String
  convertedLeadId String?

  sourceContent ContentItem? @relation(fields: [sourceContentId], references: [id])
  convertedLead Lead?        @relation(fields: [convertedLeadId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([addedAt])
  @@index([sourceContentId])
  @@index([status])
}

/// 公式LINEに届いた**受信**メッセージ（LineMessage は配信＝送信側なので別）。
///
/// ★なぜ要るか
///   2026-07-22、購入検討中の方から公式LINEに2件の問い合わせが来ていたが、
///   誰も気づいていなかった。MMS は公式LINEを「未計測」として扱っており、
///   通知経路も無かった。獲得3ゴールの③そのものが素通りしていた。
///
/// ★本文は保存しない。MMS が持つのは PDCA に使う数（件数）だけで、
///   内容は LINE 公式アカウント側にある。持たなければ守る必要も無い（§16.2）。
model LineInbound {
  id         String   @id @default(cuid())
  lineUserId String
  receivedAt DateTime
  /// text / image / sticker / file …
  kind       String
  /// 対応済みにした日時。null は未対応（見落としの検知に使う）
  handledAt  DateTime?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receivedAt])
  @@index([lineUserId])
  @@index([handledAt])
}

/// §3 ══7. LINE配信（LINE Messaging API で反応が取得可能）
model LineMessage {
  id         String   @id @default(cuid())
  /// 値の列挙が設計書に無いため String（§13 記録済）
  kind       String
  sentAt     DateTime
  targetTags String[]
  delivered  Int      @default(0)
  opened     Int      @default(0)
  clicked    Int      @default(0)
  blocked    Int      @default(0)

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sentAt])
  @@index([kind])
}

// ═══════════════════════════════════════════════════════════════════════════
//  ══ 8. KW・ネタ ══
// ═══════════════════════════════════════════════════════════════════════════

/// §3 ══8. キーワードマスタ（月ごとに分断されていた戦略シートを統合・§13.1）
model Keyword {
  id               String       @id @default(cuid())
  businessId       String
  keyword          String
  slug             String
  volume           Int?
  difficulty       Int?
  cpc              Float?
  /// 値の列挙が §3 に無いため String（§14.1 で informational/commercial に言及・§13 記録済）
  intent           String?
  budgetTier       BudgetTier   @default(unknown)
  funnelStage      FunnelStage?
  productFit       String[]
  /// 値の列挙が設計書に無いため String（§13 記録済）
  priority         String?
  /// 値の列挙が設計書に無いため String（§13 記録済）
  status           String?
  /// §3.3.7 市場を「商材／テーマ」単位で束ねる
  keywordClusterId String?
  /// ★AI Overview の**引用ドメイン**まで取得するか（§3.3.6）。
  ///   AIOの「有無」は全KWで取れるが、引用元の取得は1SERPあたり約5倍の
  ///   コストがかかる（実測 $0.0006 → $0.0030）。主戦場KWだけONにする運用。
  ///   ★コストが伴う判断なので .env ではなく画面から切り替える（§12.3）
  aioTracked       Boolean   @default(false)

  business       Business        @relation(fields: [businessId], references: [id])
  keywordCluster KeywordCluster? @relation(fields: [keywordClusterId], references: [id])

  assignments        KeywordAssignment[]
  research           KeywordResearch[]
  rankings           KeywordRanking[]
  volumes            KeywordVolume[]
  serpSnapshots      SerpSnapshot[]
  opportunities      Opportunity[]
  seasonalityIndexes SeasonalityIndex[]
  targetOfClusters   TopicCluster[]      @relation("ClusterTargetKeyword")
  ideas              Idea[]
  interventions      Intervention[]
  sourcedLeads       Lead[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, keyword])
  @@index([businessId])
  @@index([budgetTier, funnelStage])
  @@index([keywordClusterId])
  @@index([priority])
}

/// §3 ══8. KWリサーチ（ラッコ・90日鮮度 → 30日前に自動再取得・§13.3）
model KeywordResearch {
  id        String   @id @default(cuid())
  keywordId String
  fetchedAt DateTime
  /// 値の列挙が設計書に無いため String（§13 記録済）
  source    String
  /// 90日鮮度。expiresAt の30日前に kw_refetch を自動起票（§7.5.2）
  expiresAt DateTime

  suggests     Json?
  related      Json?
  cooccurrence Json?
  competitorH2 Json?
  /// §13.4-② 未回答のものを Idea として自動起票
  qaQuestions  Json?

  keyword Keyword @relation(fields: [keywordId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keywordId, fetchedAt])
  @@index([expiresAt])
}

/// §3 ══8. KW ↔ 記事の割当
/// ★@@unique([keywordId, role]) により main 重複＝カニバリを DB 制約で検出（§3.1）
model KeywordAssignment {
  id            String         @id @default(cuid())
  keywordId     String
  contentItemId String
  role          AssignmentRole

  keyword     Keyword     @relation(fields: [keywordId], references: [id])
  contentItem ContentItem @relation(fields: [contentItemId], references: [id])

  /// ★設計書に明記。main が1KWにつき1記事しか持てないことでカニバリを検出する

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([keywordId, role])
  @@index([contentItemId])
}

/// §3 ══8. KW別の順位履歴（striking distance 11〜20位の自動抽出元・§13.3）
/// §3.2.2: ★日次を永久保持
model KeywordRanking {
  id          String   @id @default(cuid())
  keywordId   String
  date        DateTime @db.Date
  position    Float
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float?

  keyword Keyword @relation(fields: [keywordId], references: [id])

  /// ★設計書に明記なし。日次 backfill の冪等性を担保するため追加（§13 記録済）

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([keywordId, date])
  @@index([keywordId, date])
  @@index([date])
  @@index([position])
}

// ══ 8.4 トピッククラスタ（ピラー/クラスター）══

/// §3 ══8.4 トピッククラスタ（★ツリー構造。分析は多次元・§3.5.1）
model TopicCluster {
  id              String       @id @default(cuid())
  businessId      String
  name            String
  slug            String
  /// ★ツリー構造（大項目 → 中項目 → 小項目）
  parentId        String?
  /// このクラスタのピラー記事（無ければ state=pillar_missing）
  pillarContentId String?
  pillarType      PillarType
  productFit      String[]
  budgetTier      BudgetTier   @default(unknown)
  funnelStage     FunnelStage?
  /// クラスタが狙う中心KW
  targetKeywordId String?
  state           ClusterState @default(healthy)
  /// 由来・判断の根拠（2026-07-23 追加）。
  /// ★「ピラーが無い」には2種類ある。**欠けている**（P1〜P3）のと
  ///   **設計上置かない**（横串）のを state だけでは区別できないため、
  ///   理由をここに残す。区別できないと、直す必要の無いものを直そうとする。
  note            String?

  business      Business       @relation(fields: [businessId], references: [id])
  parent        TopicCluster?  @relation("ClusterTree", fields: [parentId], references: [id])
  children      TopicCluster[] @relation("ClusterTree")
  pillarContent ContentItem?   @relation("ClusterPillar", fields: [pillarContentId], references: [id])
  targetKeyword Keyword?       @relation("ClusterTargetKeyword", fields: [targetKeywordId], references: [id])

  members ContentCluster[]
  /// ★TopicCluster 側の市場規模・シェアは ClusterMetric.marketVolume / .clickShare が持つ。
  ///   MarketShare / SeasonalityIndex は KeywordCluster 側（§13-D2 の決定）
  metrics ClusterMetric[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([parentId])
  @@index([state])
}

/// §3 ══8.4 記事 ↔ クラスタ（★多対多。1記事が複数クラスタに属せる）
/// role=primary はツリー表示に使う（1記事1つ）
model ContentCluster {
  id            String      @id @default(cuid())
  contentItemId String
  clusterId     String
  role          ClusterRole

  contentItem ContentItem  @relation(fields: [contentItemId], references: [id])
  cluster     TopicCluster @relation(fields: [clusterId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentItemId, clusterId])
  @@index([clusterId, role])
}

/// §3 ══8.4 内部リンクグラフ（現 media.db links の正規版・599本）
/// §3.5.2: トピッククラスタの本質は「数」ではなく「リンク構造」
model InternalLink {
  id             String           @id @default(cuid())
  srcContentId   String
  dstContentId   String
  anchorText     String?
  contextSection String?
  detectedAt     DateTime
  linkType       InternalLinkType

  srcContent ContentItem @relation("LinkSource", fields: [srcContentId], references: [id])
  dstContent ContentItem @relation("LinkTarget", fields: [dstContentId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([srcContentId, dstContentId, anchorText])
  @@index([srcContentId])
  @@index([dstContentId])
  @@index([linkType])
}

/// §3 ══8.4 ★グループ単位の集計（記事単位ではノイズが多すぎる・§3.5.3）
/// クリック142/週 ÷ 157本 = 週1件未満。グループに束ねると母数が10〜30倍になる
model ClusterMetric {
  id          String   @id @default(cuid())
  clusterId   String
  date        DateTime @db.Date
  /// 値の列挙が設計書に無いため String（§13 記録済）
  granularity String

  articleCount  Int
  pillarPresent Boolean

  impressions Int    @default(0)
  clicks      Int    @default(0)
  avgPosition Float?
  pv          Int    @default(0)

  top3Count  Int @default(0)
  top10Count Int @default(0)
  top20Count Int @default(0)

  /// ★グループ別のCV貢献（最重要）
  leads   Int     @default(0)
  deals   Int     @default(0)
  revenue Decimal @default(0) @db.Decimal(14, 2)

  /// 買い手適合クリックの割合
  buyerFitClickShare Float?
  /// §3.3 と接続
  marketVolume       Int?
  clickShare         Float?
  /// 相互リンク充足率（0-1）。0.8未満は要修復（§3.5.4）
  linkHealthScore    Float?
  /// 同一クラスタ内のmain KW重複。1件でも要整理
  cannibalCount      Int    @default(0)

  cluster TopicCluster @relation(fields: [clusterId], references: [id])

  /// ★設計書に明記なし。日次バッチの冪等性を担保するため追加（§13 記録済）

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clusterId, date, granularity])
  @@index([clusterId, date])
  @@index([date])
}

// ══ 8.5 市場規模・シェア・競合 ══

/// §3 ══8.5 検索ボリュームは変動する → 履歴で持つ（§3.3.1）
/// ⚠️ 推定値。絶対値を信じず、相対比較と推移で使う
model KeywordVolume {
  id        String       @id @default(cuid())
  keywordId String
  /// "YYYY-MM"（C-4）
  month     String
  volume    Int
  source    VolumeSource

  keyword Keyword @relation(fields: [keywordId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([keywordId, month, source])
  @@index([month])
}

/// §3 ══8.5 市場を「商材／テーマ」単位で束ねる（ML | IoTビーコン | 外貨両替機 | GPU …）
/// ★TopicCluster とは別概念（§13 記録済: MarketShare.clusterId がどちらを指すか未確定）
model KeywordCluster {
  id         String   @id @default(cuid())
  businessId String
  name       String
  productFit String[]

  business Business  @relation(fields: [businessId], references: [id])
  keywords Keyword[]

  /// ★§13-D2 の決定: 「市場（クラスタ）」の正は KeywordCluster（商材／テーマ単位）。
  ///   marketVolume = Σ KeywordVolume（所属 Keyword 経由）で算出できるのはこちらだけ
  marketShares       MarketShare[]
  seasonalityIndexes SeasonalityIndex[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
}

/// §3 ══8.5 対象KWの検索結果1〜20位を丸ごと保存（競合の動きを追う・§3.3.5）
/// コスト実測: DataForSEO SERP $0.60/1,000 SERP。300KW×週次で約$0.72/月
model SerpSnapshot {
  id              String   @id @default(cuid())
  keywordId       String
  date            DateTime @db.Date
  position        Int
  domain          String
  url             String
  title           String?
  isOurs          Boolean  @default(false)
  /// §3.3.6 AIO有無でCTR曲線を分ける
  hasAiOverview   Boolean  @default(false)
  aioCitedDomains String[]

  keyword Keyword @relation(fields: [keywordId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([keywordId, date, position])
  @@index([date, domain])
  @@index([domain])
  @@index([isOurs])
}

/// §3 ══8.5 競合ドメインの強さ
model Competitor {
  id        String  @id @default(cuid())
  domain    String  @unique
  label     String?
  isTracked Boolean @default(true)

  metrics           CompetitorMetric[]
  domainAuthorities DomainAuthority[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isTracked])
}

/// §3 ══8.5 追跡KW群における相対的な強さ（月次）
model CompetitorMetric {
  id           String @id @default(cuid())
  competitorId String
  /// "YYYY-MM"（C-4）
  month        String

  top3Count   Int    @default(0)
  top10Count  Int    @default(0)
  avgPosition Float?

  /// CTR曲線から推定
  estimatedClicks Int?
  shareOfClicks   Float?

  /// DataForSEO Domain Analytics（任意）
  rankedKeywords Int?
  /// DataForSEO Backlinks（任意）
  backlinks      Int?
  refDomains     Int?

  competitor Competitor @relation(fields: [competitorId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([competitorId, month])
  @@index([month])
}

/// §3 ══8.5 ★自社GSC実測から作る順位別CTR（外部の一般値より精度が高い・§3.3.2）
model CtrCurve {
  id           String   @id @default(cuid())
  position     Int
  ctr          Float
  sampleSize   Int
  calculatedAt DateTime
  /// all | comparison | product_deep …（設計書の列挙が `…` で打ち切られているため String）
  segment      String

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([position, segment, calculatedAt])
  @@index([segment, position])
}

/// §3 ══8.5 クラスタ単位のシェア（月次・自動算出・§3.3.2）
/// 表示シェア = 自社impressions ÷ クラスタのmarketVolume
/// クリックシェア = 自社clicks ÷ Σ(volume × CTR曲線[自社順位])
model MarketShare {
  id        String @id @default(cuid())
  clusterId String
  /// "YYYY-MM"（C-4）
  month     String

  /// Σ KeywordVolume（＝ニーズ規模）
  marketVolume   Int
  ourImpressions Int @default(0)
  ourClicks      Int @default(0)

  /// SOV
  impressionShare Float?
  clickShare      Float?

  /// 1ページ目食い込み率（§3.3.3）。現状: 4〜10位に78本滞留・1〜3位は0本
  top3Rate  Float?
  top10Rate Float?
  top20Rate Float?

  aioCitationRate Float?

  /// ★§13-D2 の決定: clusterId は **KeywordCluster**（商材／テーマ単位の市場）を指す。
  ///   根拠: marketVolume = Σ KeywordVolume は Keyword を束ねる KeywordCluster でしか算出できず、
  ///   TopicCluster 側の市場・シェアは ClusterMetric が既に持っている（二重定義を避ける）
  cluster KeywordCluster @relation(fields: [clusterId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clusterId, month])
  @@index([month])
}

/// §3 ══8.5 ★機会損失の定量化（優先順位の根拠・§3.3.4）
/// 機会クリック = volume × CTR曲線[目標順位] − 現在のclicks
/// 推定リード   = 機会クリック × 実測CV率（Lead / clicks）
/// ★volume だけでなく budgetTier で重み付けする（買い手でないKWに投資しない）
model Opportunity {
  id        String @id @default(cuid())
  keywordId String
  /// "YYYY-MM"（C-4）
  month     String

  volume          Int
  currentPosition Float?
  currentClicks   Int    @default(0)
  targetPosition  Float
  potentialClicks Int

  /// potential - current
  clickGap       Int
  /// clickGap × 実測CV率
  estimatedLeads Float?

  /// 難易度と掛けて自動採点
  effortScore   Float?
  priorityScore Float?

  /// ★同じKWを広告で買った場合の単価
  paidCpc         Float?
  /// ★同じクリック数を広告で買う金額 → SEO vs 広告の比較（§3.4.7 週次）
  paidCostToMatch Float?

  keyword Keyword @relation(fields: [keywordId], references: [id])

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([keywordId, month])
  @@index([month, priorityScore])
}

// ══ 8.6 有料広告 ══

/// §3 ══8.6 広告アカウント
model AdAccount {
  id         String     @id @default(cuid())
  businessId String
  platform   AdPlatform
  externalId String
  name       String
  /// 値の列挙が設計書に無いため String（§13 記録済）
  status     String

  business  Business     @relation(fields: [businessId], references: [id])
  campaigns AdCampaign[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, externalId])
  @@index([businessId])
}

/// §3 ══8.6 キャンペーン
model AdCampaign {
  id          String    @id @default(cuid())
