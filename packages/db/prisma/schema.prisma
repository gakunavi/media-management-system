/// §3 ══8.6 広告クリエイティブ
/// ⚠️ YMYL領域（§3.4.6）: 「必ず節税できる」等の断定表現は tax-accuracy ルールで禁止
model AdCreative {
  id         String  @id @default(cuid())
  adGroupId  String
  externalId String
  headline   String
  body       String
  imageUrl   String?
  landingUrl String
  /// 値の列挙が設計書に無いため String（§13 記録済）
  status     String

  adGroup AdGroup         @relation(fields: [adGroupId], references: [id])
  metrics AdMetricDaily[]

  /// §9-D11: 監査・障害調査用のタイムスタンプ（設計書に記載は無いが P0-a で全モデルに付与）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adGroupId, externalId])
