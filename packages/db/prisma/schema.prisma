  endedAt     DateTime?

  adAccount AdAccount    @relation(fields: [adAccountId], references: [id])
  targetLp  LandingPage? @relation(fields: [targetLpId], references: [id])

  adGroups          AdGroup[]
  metrics           AdMetricDaily[]
  linkedSimulations AdSimulation[]

