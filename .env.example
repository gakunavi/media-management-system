# ════════════════════════════════════════════════════════════════
#  MMS 環境変数（設計書 §8 / docs/RULES.md §12）
#  使い方:  cp .env.example .env  してから値を埋める
#  ★.env は絶対にコミットしない（.gitignore 済み）
#  ★環境変数の接頭辞は MMS_*（AUTH_* は Auth.js が要求する固定名）
# ════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────
MMS_POSTGRES_USER=mms
MMS_POSTGRES_PASSWORD=change-me-please
MMS_POSTGRES_DB=mms
# ★ホスト側に別の PostgreSQL（Homebrew 等）が 5432 で動いていると衝突する。
#   その場合はここを 5433 などに変える（コンテナ内は常に 5432）
MMS_POSTGRES_PORT=5433

# コンテナ間は db ホスト名で解決する。
# ★ホストから直接 npm run dev するときは @localhost:<MMS_POSTGRES_PORT> に読み替える
MMS_DATABASE_URL=postgresql://mms:change-me-please@db:5432/mms?schema=public

# ── 認証（Auth.js v5）──────────────────────────────────────────
# 生成: openssl rand -base64 32
AUTH_SECRET=

# ブラウザからアクセスする URL。Cloudflare Tunnel 経由ならその URL にする
MMS_PUBLIC_URL=http://localhost:3000

# npm run db:seed で role=owner のユーザーを作るメールアドレス。
# ★未設定だと初回ログインしたユーザーは role=readonly になる
MMS_OWNER_EMAIL=

# ── メール（マジックリンク送信）────────────────────────────────
# ★未設定でも動く。その場合ログインリンクは web のログに出力される
#   （docker compose logs -f web）。本番では必ず設定する。
MMS_SMTP_HOST=
MMS_SMTP_PORT=587
MMS_SMTP_USER=
MMS_SMTP_PASS=
MMS_SMTP_FROM=mms@example.com

# ── web / worker ───────────────────────────────────────────────
MMS_WEB_PORT=3000
MMS_WORKER_POLL_SECONDS=20

# ── 以降の Phase で使う（P2 以降）──────────────────────────────
# 計測 Webhook の HMAC-SHA256 共有シークレット（§8）
# MMS_INGEST_SECRET=
# WordPress REST（P1.8 で書き込みを MMS 一本化する）
# MMS_WP_BASE_URL=
# MMS_WP_USER=
# MMS_WP_APP_PASSWORD=

# ── P1: 既存 Python 資産（§6「書き直さない」）───────────────────
# メディア事業部の .claude/scripts/ を worker に**読み取り専用でマウント**する。
# ★コピーしないので本体と乖離しない。未設定なら services/worker/legacy/ を使う
MMS_LEGACY_SCRIPTS_DIR=/Users/ishiimasataka/Documents/Claude/Projects/メディア事業部/.claude/scripts
# 移行元 SQLite の置き場（scripts/migrate-legacy.py が読む）
MMS_LEGACY_MEDIA_ROOT=/Users/ishiimasataka/Documents/Claude/Projects/メディア事業部

# ── P2: 計測受口とリード（§8 / §16.2）────────────────────────────
# Webhook の HMAC-SHA256 共有シークレット。WPプラグイン / GAS に同じ値を入れる
# 生成: openssl rand -hex 32
MMS_INGEST_SECRET=
# ★個人情報の列単位暗号化キー（§16.2）。未設定だと ingest は 503 を返す（fail-closed）
# 生成: openssl rand -base64 32
# ⚠️ この鍵を失うと既存の個人情報は復号できない。バックアップ対象（§16.4）
MMS_PII_KEY=
# /api/ingest の1分あたり上限（§3.10.4 サーバー側の歯止め）
MMS_INGEST_RATE_LIMIT=30
MMS_DEFAULT_BUSINESS_SLUG=tax-saving-agency

# ── 即時通知（§5.4「石井さんへ即通知（最優先）」）──────────────
# 設定した経路すべてに送る。未設定ならサーバーログのみ
MMS_NOTIFY_WEBHOOK_URL=
MMS_NOTIFY_EMAIL=

# ── このMac専用の自動ログイン（localhost のみ・外部では無効）──────
# ★設定すると localhost:3000 でメール入力なしにこのアカウントでログインする。
#   Cloudflare Tunnel 経由（Host が公開ドメイン）では作動しない安全設計。
#   空にすると通常のマジックリンク方式に戻る。
MMS_DEV_AUTOLOGIN_EMAIL=

# ── 計測タグ（ファネル7段・P2.5）────────────────────────────────
# タグを送ってよいオリジン（カンマ区切り）。★未設定だと全許可（開発用）。
# 本番では必ず設定する: MMS_INGEST_ALLOWED_ORIGINS=https://asset-support.co.jp
MMS_INGEST_ALLOWED_ORIGINS=

# ── 内部ジョブ（worker → web の立案/判定呼び出し・§5.1）────────
# 生成: openssl rand -hex 32。★未設定だと /api/jobs/* は 503（fail-closed）
MMS_JOB_SECRET=
# worker から見た web の URL（compose 内は http://web:3000）
MMS_WEB_INTERNAL_URL=http://web:3000

# ── GSC 日次取得（§3.2.2・builtin/gsc_daily.py）────────────────
# サービスアカウント鍵は secrets/gsc-service-account.json に置く（gitignore済み）
MMS_GSC_SITE_URL=https://asset-support.co.jp/

# ── WordPress 同期（§3.9.1 日次ハッシュ突合・読み取りのみ）────────
# メディア事業部の .env（WP_SITE / WP_USER / WP_PASS）と同じ値
MMS_WP_BASE_URL=https://asset-support.co.jp
MMS_WP_USER=
MMS_WP_APP_PASSWORD=
MMS_WP_POST_TYPE=blog

# ── Threads 同期（§13.4-④・builtin/threads_sync.py）─────────────
# ★MMS は Threads API を叩かない。トークンは GAS 側に置いたままでよい。
#   GAS の Api.gs が持つ Web App API から **MMS が pull** する方式のため、
#   MMS を外部公開する必要はない（Cloudflare Tunnel 不要）。
# GAS エディタ → デプロイ → ウェブアプリ で発行された /exec で終わる URL
MMS_THREADS_GAS_URL=
# GAS の スクリプトプロパティ API_KEY と同じ値
MMS_THREADS_GAS_KEY=
# 複数アカウント運用に備えた識別子（§11.3 投稿の分離ガード）
MMS_THREADS_ACCOUNT_REF=setsuzei_masa
